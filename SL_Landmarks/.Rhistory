scale_fill_discrete(
name = "Vertebra",                      # fill legend title
labels = c("0% SL", "25% SL", "50% SL", "75% SL", "100% SL")  # replace with your actual labels
) +
guides(fill = guide_legend(override.aes = list(size = 5))) +  # change 5 to your preferred size
labs(
x = paste0("PC2 (", round(percent_var[2], 1), "%)"),
y = paste0("PC3 (", round(percent_var[3], 1), "%)"),
) +
theme_black() +
theme(
axis.title = element_text(size = 8),
axis.text  = element_text(size = 7)
) +
coord_fixed(ratio = 1.25)
combined_plot <- PC1v2plot / PC2v3plot + plot_layout(guides = "collect")
ggsave("GMPCAPlotsCombined.png", plot = combined_plot, width = 6, height = 7.5, units = "in", bg = "black")
